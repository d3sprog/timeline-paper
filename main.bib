@inproceedings{ischard-2025-frp,
author = {Ischard, Jordan and Dabrowski, Fr\'{e}d\'{e}ric and Chouquet, Jules and Loulergue, Fr\'{e}d\'{e}ric},
title = {A Mechanized Formalization of an FRP Language with Effects},
year = {2025},
isbn = {9798400706295},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3672608.3707907},
doi = {10.1145/3672608.3707907},
abstract = {Functional Reactive Programming (FRP) is a functional programming paradigm designed for systems interacting with their environment. The Yampa library, a Haskell implementation, allows users to construct signal functions that synchronously process input streams to produce output streams. While this library facilitates concise and robust coding, managing I/O is cumbersome. To address this issue, the Wormholes library extends Yampa with constructs to bind I/O to resource names, accessible in an imperative style. Few FRP languages are formalized, and Wormholes added challenging features. This article presents a mechanized formalization of a slightly modified version of Wormholes, improving the result and correcting some issues.},
booktitle = {Proceedings of the 40th ACM/SIGAPP Symposium on Applied Computing},
pages = {1431–1439},
numpages = {9},
keywords = {functional programming, reactive programming, effects, interactive theorem proving},
location = {Catania International Airport, Catania, Italy},
series = {SAC '25}
}

@inproceedings{jeltsch-2014-categorical,
author = {Jeltsch, Wolfgang},
title = {An abstract categorical semantics for functional reactive programming with processes},
year = {2014},
isbn = {9781450325677},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/2541568.2541573},
doi = {10.1145/2541568.2541573},
abstract = {Linear-time temporal logic and functional reactive programming (FRP) are related via a Curry-Howard correspondence. Thereby proofs of "always," "eventually," and "until" propositions correspond to behaviors, events, and processes, respectively. Processes in the FRP sense combine continuous and discrete aspects and generalize behaviors and events. In this paper, we develop a class of axiomatically defined categorical models of FRP with processes. We call these models abstract process categories (APCs). We relate APCs to other categorical models of FRP, namely temporal categories and concrete process categories.},
booktitle = {Proceedings of the ACM SIGPLAN 2014 Workshop on Programming Languages Meets Program Verification},
pages = {47–58},
numpages = {12},
keywords = {functional reactive programming, curry-howard correspondence, category theory, categorical semantics},
location = {San Diego, California, USA},
series = {PLPV '14}
}
