@inproceedings{bazant-2018-nontabular,
  title = {A Non-Tabular Spreadsheet with Broad Applicability},
  booktitle = {Companion {{Proceedings}} of the 2nd {{International Conference}} on the {{Art}}, {{Science}}, and {{Engineering}} of {{Programming}}},
  author = {Ba{\v z}ant, Pavel and Mar{\v s}{\'a}lkov{\'a}, Michaela},
  year = 2018,
  month = apr,
  series = {Programming '18},
  pages = {161--165},
  publisher = {Association for Computing Machinery},
  address = {New York, NY, USA},
  doi = {10.1145/3191697.3214343},
  urldate = {2025-06-23},
  abstract = {We present Nezt -- a prototype of a live programming environment inspired by spreadsheets, but with a more expressive computational model. In contrast to traditional spreadsheets, cells can contain other cells in a hierarchical fashion, and one can define custom functions and use them in formulas. Our goal is to share some of the accessibility, immediacy and ease of use of spreadsheets, while achieving broad applicability, especially in the areas of application prototyping and scientific computing. The project is motivated by our own needs, but we hope it could be useful to many different types of users including advanced end-users like scientists who program as part of their work. Design influences include Excel, Lisp, JetBrains MPS and Boxer. The ultimate goal is a versatile live programming environment without the accidental complexities of mainstream professional programming.},
  isbn = {978-1-4503-5513-1}
}

